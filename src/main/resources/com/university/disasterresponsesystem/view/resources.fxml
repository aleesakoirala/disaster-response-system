<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.university.disasterresponsesystem.client.controller.ResourceController">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
    <Label text="Resource Management" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Label text="Add resource"/>
    <HBox spacing="8">
        <TextField fx:id="nameField" promptText="Resource name"/>
        <ChoiceBox fx:id="deptChoice"/>
        <Button text="Add" onAction="#handleAdd"/>
    </HBox>

    <Label text="Dispatch resource to incident"/>
    <HBox spacing="8">
        <TextField fx:id="resourceIdField" promptText="Resource ID"/>
        <TextField fx:id="incidentIdField" promptText="Incident ID"/>
        <Button text="Allocate" onAction="#handleAllocate"/>
    </HBox>

    <Label text="Resources"/>
    <ListView fx:id="resourceList" prefHeight="240"/>
    <HBox spacing="8">
        <Button text="Refresh" onAction="#refresh"/>
    </HBox>
    <Label fx:id="messageLabel" style="-fx-text-fill: #2c3e50;"/>
</VBox>
